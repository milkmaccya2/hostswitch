  "repository": {
    "type": "git",
    "url": "https://github.com/milkmaccya2/hostswitch.git"
  },
  "bugs": {
    "url": "https://github.com/milkmaccya2/hostswitch/issues"
  },
  "homepage": "https://github.com/milkmaccya2/hostswitch#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "preferGlobal": true,
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "jest": "^30.0.3"
  }
