{
  "name": "@milkmaccya2/hostswitch",
  "version": "1.0.2",
  "description": "A simple CLI tool to manage and switch between multiple hosts file profiles for different development environments",
  "main": "hostswitch.js",
  "bin": {
    "hostswitch": "./hostswitch.js"
  },
  "scripts": {
